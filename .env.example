# ── Pharos Network ────────────────────────────────────────
PHAROS_RPC=https://atlantic.dplabs-internal.com/

# ── Wallet (your Pharos agent wallet private key) ─────────
# Get testnet PHRS: https://pharos.xyz/faucet
EVM_PRIVATE_KEY=your_private_key_here

# ── x402 Payment Config ───────────────────────────────────
# Address that receives 0.01 USDC per audit call
PAY_TO_ADDRESS=0xYourReceivingAddress

# Facilitator service URL (run locally or use hosted)
FACILITATOR_URL=http://localhost:3000

# USDC on Pharos Atlantic Testnet (test token, not official)
USDC_ADDRESS=0xE0BE08c77f415F577A1B3A9aD7a1Df1479564ec8

# ── LLM for Semantic Analysis ─────────────────────────────
# Supports any OpenAI-compatible endpoint
# Use OpenAI: set OPENAI_API_KEY
# Use local LLM: set LLM_BASE_URL=http://localhost:11434/v1
OPENAI_API_KEY=your_openai_api_key_here
LLM_MODEL=gpt-4o-mini
# LLM_BASE_URL=  # optional: override for local/custom LLM

# ── Server Config ─────────────────────────────────────────
PORT=4022

# ── Client Config ─────────────────────────────────────────
GUARDIAN_SKILL_URL=http://localhost:4022
